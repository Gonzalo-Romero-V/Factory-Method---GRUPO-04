@startuml c4-context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title Diagrama de Contexto — Sistema de Biblioteca Digital

Person(usuario, "Usuario", "Estudiante o docente que solicita préstamos de recursos académicos.")

System(biblioteca, "Sistema de Biblioteca Digital", "Registra préstamos de recursos académicos.\nUsa el Patrón Factory Method para crear recursos.")

System_Ext(notif, "Sistema de Notificaciones", "Emite confirmaciones de préstamo al usuario (simulado por consola).")

Rel(usuario, biblioteca, "Solicita préstamos de recursos")
Rel(biblioteca, notif, "Genera notificación al confirmar préstamo")

SHOW_LEGEND()
@enduml
