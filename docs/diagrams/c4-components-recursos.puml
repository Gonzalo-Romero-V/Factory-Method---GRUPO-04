@startuml c4-components-recursos
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Diagrama de Componentes — Módulo de Recursos (Factory Method)

Container_Boundary(app, "Aplicación de Consola") {
    Component(main, "Main", "Java Class", "Orquesta el flujo completo: usuario, recursos, prestamo, DB, resumen.")
    Component(factory_abs, "RecursoFactory", "Abstract Class (Creator)", "Declara el Factory Method: crearRecurso(tipo): RecursoBibliografico")
    Component(factory_conc, "BibliotecaFactory", "Class (ConcreteCreator)", "Implementa crearRecurso(). Instancia el tipo concreto segun el parametro. Lanza excepcion si el tipo no existe.")
    Component(recurso_abs, "RecursoBibliografico", "Abstract Class (Product)", "Define: titulo, autor, codigo, costoBase, calcularCosto(), obtenerDescripcion(), agregarServicio()")
    Component(recursos, "LibroFisico / LibroDigital / Revista / Tesis / Audiolibro", "Classes (ConcreteProduct)", "Extienden RecursoBibliografico. Cada uno valida su servicio permitido en agregarServicio().")
    Component(servicio_iface, "ServicioAdicional", "Interface", "getCosto(), getDescripcion(), getTipo()")
    Component(servicios, "EnvioDomicilio / DescargaOffline / PrestamoExtendido / CertificadoLectura / AccesoPremium", "Classes", "Implementan ServicioAdicional. Se agregan por composicion.")
    Component(prestamo, "Prestamo + DetallePrestamo + Notificacion", "Classes", "Agrupa recursos por usuario. Calcula costo total. Genera notificacion.")
    Component(repo, "PrestamoRepository", "Class (DB Layer)", "Persiste Prestamo, DetallesPrestamo, Servicios y Notificacion en H2 via JDBC.")
}

Rel(main, factory_conc, "crearRecurso(tipo)")
Rel(factory_conc, factory_abs, "extiende")
Rel(factory_conc, recursos, "instancia segun tipo")
Rel(recursos, recurso_abs, "extienden")
Rel(recursos, servicios, "valida y agrega")
Rel(servicios, servicio_iface, "implementan")
Rel(main, prestamo, "agrega recursos, calcula costo")
Rel(main, repo, "save(prestamo)")

SHOW_LEGEND()
@enduml
